---
import '../styles/globals.css';
import Header from '@/components/Header.jsx';
import Footer from '@/components/Footer.jsx';
import AP0110MonoProvider from '@/components/AP0110MonoProvider.jsx';

const {
  title = 'AP0110 — Independent Internet (Web 4.0)',
  description = 'AP0110 builds Independent Internet (Web 4.0) — open-source mesh networking, decentralized protocols, and post-quantum security for user-owned internet infrastructure.',
  keywords = 'Web 4.0, Independent Internet, decentralized internet, mesh networking, AP0110, post-quantum security, edge computing, user-owned internet, decentralized protocols',
  image = '/images/AP0110_moon_black.webp',
  // og:type — 'website' for most pages, 'article' for blog posts/docs.
  ogType = 'website',
  // Optional per-page structured data (array of schema.org objects), rendered
  // alongside the site-wide Organization + WebSite graph.
  jsonLd = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site).href;
const mdMirror =
  (Astro.url.pathname === '/' ? '/index' : Astro.url.pathname.replace(/\/$/, '')) + '.md';

// Shared chrome — see AP0110.com. Header/Footer are byte-identical across repos;
// all per-site differences are props (theme=light, .org nav/footer content).
const navItems = [
  { type: 'link', label: 'Web 4.0', href: '/wiki/web4' },
  { type: 'link', label: 'About', href: '/about' },
  { type: 'link', label: 'Wiki', href: '/wiki' },
  { type: 'link', label: 'Docs', href: '/docs' },
];
const footerSections = [
  {
    title: 'Projects',
    items: [
      { label: 'CalCompute', href: '/calcompute' },
      { label: 'UNA-USA DPI', href: '/unausa' },
      { label: 'Children', href: '/children' },
    ],
  },
  {
    title: 'Navigation',
    items: [
      { label: 'About Us', href: '/about' },
      { label: 'Web 4.0', href: '/wiki/web4' },
      { label: 'Wiki', href: '/wiki' },
      { label: 'Glossary', href: '/wiki/glossary' },
      { label: 'Docs', href: '/docs' },
      { label: 'Articles', href: '/articles' },
    ],
  },
];

// Site-wide Organization + WebSite graph (ported from the old Next root layout).
const organizationSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://ap0110.org/#organization',
      name: 'AP0110.ORG',
      url: 'https://ap0110.org',
      logo: {
        '@type': 'ImageObject',
        url: 'https://ap0110.org/images/AP0110_moon_black.webp',
      },
      description:
        'AP0110 builds Independent Internet (Web 4.0) — open-source mesh networking, decentralized protocols, and post-quantum security for user-owned internet infrastructure.',
      email: 'contact@ap0110.com',
      sameAs: ['https://github.com/AP0110-Systems'],
    },
    {
      '@type': 'WebSite',
      '@id': 'https://ap0110.org/#website',
      url: 'https://ap0110.org',
      name: 'AP0110.org',
      description:
        'Independent Internet (Web 4.0) technology, decentralized networking, and charitable technology initiatives.',
      publisher: { '@id': 'https://ap0110.org/#organization' },
    },
  ],
};
---

<!doctype html>
<html lang="en" class="overflow-x-hidden max-w-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#000000" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="AP0110 Inc." />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" type="text/markdown" href={mdMirror} />

    <!-- Fonts — self-hosted Kunst Grotesk (public/fonts/); @font-face in globals.css -->
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/Kunst%20Grotesk%20Regular.woff2"
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/Kunst%20Grotesk%20Medium.woff2"
      crossorigin
    />
    <style>
      body { font-family: 'Kunst Grotesk', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif; }
    </style>

    <link rel="preload" as="image" href="/images/AP0110_moon_black.webp" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="AP0110.org" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicons -->
    <link rel="icon" href="/favicons/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicons/favicon.svg" type="image/svg+xml" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicons/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicons/favicon-32x32.png" />
    <link rel="apple-touch-icon" href="/favicons/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    {jsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <!-- Per-page <head> additions (e.g. section-specific font links) -->
    <slot name="head" />
  </head>
  <body class="overflow-x-clip max-w-full">
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[60] focus:px-4 focus:py-2 focus:bg-ap-cyan focus:text-black focus:rounded-sm focus:font-medium">Skip to content</a>
    <AP0110MonoProvider client:load />
    <Header
      navItems={navItems}
      theme="light"
      logoText="AP0110.ORG"
      cta={null}
      showSearch
      pathname={Astro.url.pathname}
      client:load
    />
    {/* overflow-x-clip (not -hidden): clips the same but doesn't create a scroll
        container, so position:sticky inside pages (wiki rails) works. */}
    <div id="main" class="w-full max-w-full overflow-x-clip">
      <slot />
    </div>
    <Footer
      theme="light"
      showSearch
      copyright="© 2026 AP0110"
      ctaButtonText="Get involved"
      brandName="AP0110.ORG"
      brandHref="/"
      otherBrands={[{ name: 'AP0110.COM', href: 'https://ap0110.com' }]}
      sections={footerSections}
      client:visible
    />
    <div id="reading-progress" style="position:fixed;top:60px;left:0;width:0;height:2px;background:#00b0ff;z-index:998;pointer-events:none" aria-hidden="true"></div>
    <script>
      const bar = document.getElementById('reading-progress');
      let ticking = false;
      function updateProgress() {
        ticking = false;
        const max = document.documentElement.scrollHeight - window.innerHeight;
        bar.style.width = max > 0 ? `${(window.scrollY / max) * 100}%` : '0%';
      }
      window.addEventListener('scroll', () => {
        if (!ticking) { ticking = true; requestAnimationFrame(updateProgress); }
      }, { passive: true });
    </script>
  </body>
</html>
