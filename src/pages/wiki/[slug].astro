---
import Layout from '@/layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { buildGraph, subgraphFor, backlinksFor } from '@/utils/wikiGraph.js';
import WikiGraph from '@/components/WikiGraph.jsx';
import WikiNav from '@/components/WikiNav.astro';
import WikiToc from '@/components/WikiToc.astro';

export async function getStaticPaths() {
  const [docs, wiki] = await Promise.all([getCollection('docs'), getCollection('wiki')]);
  const graph = buildGraph(docs, wiki);
  const byId = new Map(graph.nodes.map((n) => [n.id, n]));
  // /wiki/web4 has its own rich static route (wiki/web4.astro) — skip it here to avoid a route collision.
  return wiki.filter((entry) => entry.id !== 'web4').map((entry) => {
    const id = `/wiki/${entry.id}`;
    return {
      params: { slug: entry.id },
      props: {
        entry,
        backlinks: backlinksFor(graph, id).map((n) => ({ id: n.id, label: n.label })),
        outlinks: (graph.linksOut.get(id) ?? [])
          .map((t) => byId.get(t))
          .filter(Boolean)
          .map((n) => ({ id: n.id, label: n.label })),
        local: subgraphFor(graph, id, 1),
      },
    };
  });
}

const { entry, backlinks, outlinks, local } = Astro.props;
const { Content, headings } = await render(entry);
const hasGraph = local.nodes.length > 1;

// "On this page" links from the rendered markdown's h2/h3.
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
const hasLinks = outlinks.length > 0 || backlinks.length > 0;
const hasNav = toc.length > 1 || hasLinks;
---

<Layout title={`${entry.data.title} — AP0110.ORG Wiki`} description={entry.data.description}>
  <div class="min-h-screen">
    {/* Hero: the synthesized page's header beside its local graph */}
    <section class="pt-32 pb-8 px-4">
      <div class={hasGraph ? 'max-w-6xl mx-auto grid md:grid-cols-2 gap-8 lg:gap-12 items-center' : 'max-w-3xl mx-auto'}>
        <div>
          <a href="/wiki/" class="inline-flex items-center gap-2 text-ap-cyan hover:text-ap-cyan/80 text-sm mb-6 group">
            <svg class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            All Wiki
          </a>
          <div class="text-xs uppercase tracking-wide text-gray-500 mb-2">{entry.data.type}</div>
          <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">{entry.data.title}</h1>
          {entry.data.description && <p class="text-lg text-gray-600 mb-4">{entry.data.description}</p>}
          <div class="flex flex-wrap items-center gap-3 text-sm text-gray-500">
            {outlinks.length > 0 && <span>Links to {outlinks.length}</span>}
            {entry.data.tags.map((tag) => (
              <a href={`/wiki/tag/${tag}/`} class="bg-ap-cyan/10 text-ap-cyan px-2 py-0.5 rounded-full text-xs font-medium hover:bg-ap-cyan/20">{tag}</a>
            ))}
          </div>
        </div>
        {hasGraph && (
          <div>
            <WikiGraph data={local} variant="classic" focusNodeId={`/wiki/${entry.id}`} client:visible />
          </div>
        )}
      </div>
    </section>

    {/* Body: docs-style rails (connected pages left, on-page links right) beside the article */}
    <section class="pb-16 px-4">
      <div class="max-w-6xl mx-auto lg:flex lg:gap-10 border-t border-gray-200 pt-10">
        {/* At lg the rail also carries the TOC (no right rail yet); at xl+ links only —
            and if a page somehow has no links, hide the rail there instead of
            rendering an empty column. */}
        {hasNav && (
          <aside class={`hidden lg:block w-52 shrink-0 ${hasLinks ? '' : 'xl:hidden'}`}>
            <div class="sticky top-20 max-h-[calc(100vh-6rem)] overflow-y-auto pb-8">
              <WikiNav outlinks={outlinks} backlinks={backlinks} toc={toc} tocClass="xl:hidden" />
            </div>
          </aside>
        )}

        <main class="min-w-0 flex-1 max-w-3xl mx-auto lg:mx-0">
          {hasNav && (
            <details class="lg:hidden mb-8 rounded-lg border border-gray-200 bg-black/5">
              <summary class="cursor-pointer px-4 py-2.5 text-sm font-medium text-gray-700 select-none">On this page &amp; linked pages</summary>
              <div class="px-4 pb-4 pt-1">
                <WikiNav outlinks={outlinks} backlinks={backlinks} toc={toc} />
              </div>
            </details>
          )}

          <article class="article-prose">
            <Content />
          </article>
        </main>

        <WikiToc toc={toc} />
      </div>
    </section>
  </div>
</Layout>
