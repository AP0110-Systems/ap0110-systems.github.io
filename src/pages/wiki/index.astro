---
import Layout from '@/layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { buildGraph, backlinksFor } from '@/utils/wikiGraph.js';
import WikiGraph from '@/components/WikiGraph.jsx';

const [wiki, docs, pages] = await Promise.all([
  getCollection('wiki'),
  getCollection('docs'),
  getCollection('pages'),
]);

// The folded-in overview thesis lives in the /wiki page mirror (single source → also feeds
// /wiki.md + llms.txt). Render its body as the index intro.
const wikiPage = pages.find((p) => p.data.route === '/wiki');
const { Content: Thesis } = wikiPage ? await render(wikiPage) : { Content: null };

const graph = buildGraph(docs, wiki);
// Only nodes/edges feed the viz island — keep buildGraph's linksOut/linksIn Maps server-side.
const graphData = { nodes: graph.nodes, edges: graph.edges };
// Inbound graph edges — how many pages reference this one. Hubs sort first within a group.
const refCount = (id) => backlinksFor(graph, `/wiki/${id}`).length;

// An analysis's subject: the doc sharing its slug, else its single outbound /docs/ link.
// Ambiguous (0 or 2+ doc links, no slug match) → no chip; never guess.
const docById = new Map(docs.map((d) => [`/docs/${d.id}`, d]));
const subjectDoc = (entry) => {
  const sameSlug = docById.get(`/docs/${entry.id}`);
  if (sameSlug) return sameSlug;
  const out = (graph.linksOut.get(`/wiki/${entry.id}`) ?? []).filter((t) => t.startsWith('/docs/'));
  return out.length === 1 ? docById.get(out[0]) : null;
};

// Live graph stats for the hero (non-overlapping: sources + syntheses = every node).
const stats = [
  { n: docs.length, label: docs.length === 1 ? 'Source' : 'Sources' },
  { n: wiki.length, label: wiki.length === 1 ? 'Synthesis' : 'Syntheses' },
  { n: graphData.edges.length, label: graphData.edges.length === 1 ? 'Connection' : 'Connections' },
];

// Catalog groups, in the wiki's reading order (Sources first as a count, then the synthesized
// types). Concepts/entities are compact title-only grids sorted most-referenced first;
// analyses are a single-column list ordered chronologically by their subject document.
const TYPE = {
  concept: { dot: 'bg-ap-cyan' },
  entity: { dot: 'bg-ap-blue' },
  analysis: { dot: 'bg-ap-violet' },
};
const GROUPS = [
  { type: 'concept', id: 'concepts', label: 'Concepts', grid: true },
  { type: 'entity', id: 'entities', label: 'Entities', grid: true },
  { type: 'analysis', id: 'analyses', label: 'Analyses', grid: false },
];
const byType = (t) => {
  const entries = wiki.filter((e) => e.data.type === t);
  if (t === 'analysis') {
    return entries.sort((a, b) => {
      const da = subjectDoc(a)?.data.date.valueOf() ?? Infinity;
      const db = subjectDoc(b)?.data.date.valueOf() ?? Infinity;
      return da - db || a.data.title.localeCompare(b.data.title);
    });
  }
  return entries.sort((a, b) => refCount(b.id) - refCount(a.id) || a.data.title.localeCompare(b.data.title));
};

---

<Layout
  title="Wiki — AP0110.ORG"
  description="A small, public knowledge graph tracing the lineage of the Independent Internet (Web 4.0) — the people, ideas, and primary documents behind decentralized computing."
>
  <div class="min-h-screen">
    {/* Hero: intro beside the whole graph at a glance (classic straight-edge layout); stacks on mobile. */}
    <section class="pt-32 pb-12 px-4">
      <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-8 lg:gap-12 items-center">
        <div class="text-center md:text-left">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ap-cyan mb-4">AP0110 Knowledge Graph</p>
          <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-5">The Wiki</h1>
          <p class="text-lg text-gray-600 leading-relaxed mb-8">{wikiPage?.data.description}</p>

          <div class="flex flex-wrap items-stretch justify-center md:justify-start divide-x divide-gray-200 mb-8">
            {stats.map((s) => (
              <div class="px-6 first:pl-0">
                <div class="text-3xl font-bold text-gray-900 tabular-nums">{s.n}</div>
                <div class="text-xs uppercase tracking-wide text-gray-500 mt-1">{s.label}</div>
              </div>
            ))}
          </div>

          <div class="flex flex-wrap gap-3 justify-center md:justify-start text-sm">
            <a href="/wiki/web4/" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-ap-cyan text-white font-medium shadow-sm hover:opacity-90 transition-opacity">Explore the graph</a>
            <a href="/docs/" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg border border-gray-300 text-gray-600 font-medium hover:border-ap-cyan hover:text-ap-cyan transition-colors">Source library &rarr;</a>
          </div>
        </div>

        {graphData.nodes.length > 0 && (
          <div>
            <WikiGraph data={graphData} variant="classic" client:visible />
          </div>
        )}
      </div>
    </section>

    {/* The thesis, lineage, and threads — the reading path through the graph. */}
    {Thesis && (
      <section class="pb-4 px-4">
        <div class="max-w-3xl mx-auto article-prose">
          <Thesis />
        </div>
      </section>
    )}

    <section class="pb-16 px-4">
      <div class="max-w-4xl mx-auto">
        {/* Sticky rail: section jump links + search, pinned below the 50px fixed header. */}
        <div class="sticky top-[50px] z-20 -mx-4 px-4 py-2.5 bg-white/90 backdrop-blur-sm border-b border-gray-200 mb-10">
          <nav class="flex gap-1 overflow-x-auto text-sm" aria-label="Jump to section">
            <a href="#sources" data-section-link="sources" class="px-2.5 py-1 rounded-md font-medium text-gray-500 hover:text-ap-cyan whitespace-nowrap transition-colors">Sources <span class="text-gray-400 tabular-nums">{docs.length}</span></a>
            {GROUPS.map((g) => (
              <a href={`#${g.id}`} data-section-link={g.id} class="px-2.5 py-1 rounded-md font-medium text-gray-500 hover:text-ap-cyan whitespace-nowrap transition-colors">{g.label} <span class="text-gray-400 tabular-nums">{byType(g.type).length}</span></a>
            ))}
          </nav>
        </div>

        {/* Sources — the raw library; cataloged as a count that links into /docs. */}
        <div id="sources" data-section class="scroll-mt-28 mb-12">
          <h2 class="text-xl font-bold text-gray-900 mb-4">Sources <span class="text-gray-400 font-normal text-base">({docs.length})</span></h2>
          <p class="text-gray-600 text-sm">One page per primary document — papers, specs, and reports — that the synthesized pages below draw on.</p>
        </div>

        {GROUPS.map((g) => {
          const entries = byType(g.type);
          if (entries.length === 0) return null;
          const t = TYPE[g.type];
          return (
            <div id={g.id} data-section class="scroll-mt-28 mb-12">
              <h2 class="flex items-center gap-2.5 text-xl font-bold text-gray-900 mb-4">
                <span class={`w-2.5 h-2.5 rounded-full ${t.dot}`}></span>
                {g.label} <span class="text-gray-400 font-normal text-base">({entries.length})</span>
              </h2>
              {/* Compact directory, not cards — descriptions/tags/link counts live on the
                  detail pages; the index only needs to be scannable. */}
              {g.grid ? (
                <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-2">
                  {entries.map((entry) => (
                    <a
                      href={`/wiki/${entry.id}/`}
                      title={entry.data.description}
                      class="group flex items-center gap-2.5 rounded-lg border border-black/10 bg-black/5 px-3.5 py-2.5 hover:border-ap-cyan/40 hover:shadow-sm transition-all"
                    >
                      <span class={`w-1.5 h-1.5 rounded-full shrink-0 ${t.dot}`}></span>
                      <span class="text-sm font-semibold text-gray-900 group-hover:text-ap-cyan transition-colors leading-snug">{entry.data.title}</span>
                    </a>
                  ))}
                </div>
              ) : (
                <ol class="border-y border-gray-200 divide-y divide-gray-200">
                  {entries.map((entry) => {
                    const subject = subjectDoc(entry);
                    return (
                      <li class="group relative flex items-baseline gap-4 py-3">
                        {/* Chronological list — the year is the subject document's, not an edit date. */}
                        <span class="w-14 shrink-0 text-xs text-gray-400 tabular-nums text-right">{subject?.data.year ?? ''}</span>
                        <div class="min-w-0">
                          {/* Stretched link: the title's ::after covers the row; the subject link sits above it at z-10. */}
                          <h3 class="text-base font-semibold text-gray-900 leading-snug">
                            <a href={`/wiki/${entry.id}/`} class="group-hover:text-ap-cyan transition-colors after:absolute after:inset-0">{entry.data.title}</a>
                            {subject && (
                              <span class="font-normal text-sm text-gray-500">
                                {' '}· on <a href={`/docs/${subject.id}/`} class="relative z-10 text-ap-violet hover:underline">{subject.data.title}</a>
                              </span>
                            )}
                          </h3>
                          {entry.data.description && (
                            <p class="text-sm text-gray-500 leading-relaxed line-clamp-1">{entry.data.description}</p>
                          )}
                        </div>
                      </li>
                    );
                  })}
                </ol>
              )}
            </div>
          );
        })}
      </div>
    </section>
  </div>
</Layout>

<script>
  // Scrollspy: highlight the catalog section currently in view on the jump rail.
  const spy = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        const link = document.querySelector(`[data-section-link="${entry.target.id}"]`);
        link?.classList.toggle('text-ap-cyan', entry.isIntersecting);
        link?.classList.toggle('bg-ap-cyan/10', entry.isIntersecting);
      }
    },
    { rootMargin: '-100px 0px -60% 0px' }
  );
  document.querySelectorAll('[data-section]').forEach((s) => spy.observe(s));
</script>
