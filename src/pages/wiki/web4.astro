---
import Layout from '@/layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { buildGraph, backlinksFor } from '@/utils/wikiGraph.js';
import WikiGraph from '@/components/WikiGraph.jsx';
import Particles from '@/components/Particles.jsx';
import GlobeViewer from '@/components/GlobeViewer.jsx';
import WikiNav from '@/components/WikiNav.astro';
import WikiToc from '@/components/WikiToc.astro';
import VerbLadder from '@/components/VerbLadder.astro';
import PrinciplesGrid from '@/components/PrinciplesGrid.astro';
import MeshDiagram from '@/components/MeshDiagram.astro';
import { createMarkdownProcessor } from '@astrojs/markdown-remark';
import remarkWiki from '@/lib/remark-wiki.mjs';

const [docs, wiki] = await Promise.all([getCollection('docs'), getCollection('wiki')]);
const graph = buildGraph(docs, wiki);
// Full graph feeds the hero viz; drop the linksOut/linksIn Maps so they aren't serialized into the island.
const { nodes, edges } = graph;
const entry = wiki.find((e) => e.id === 'web4');
const { headings } = await render(entry);
// Split the body into its ## sections so each diagram sits inline with the prose it
// illustrates, instead of stacking above the article. Same remark pipeline as the site
// build, so heading IDs match the TOC slugs. web4.md stays the single source — the .md
// mirror, wiki graph, and search index still render from it untouched.
// ponytail: naive split on "## " at line start — fine here (no code fences in this page).
const mdProcessor = await createMarkdownProcessor({ remarkPlugins: [remarkWiki] });
const sections = await Promise.all(
  entry.body.split(/^(?=## )/m).map(async (chunk) => ({
    heading: chunk.match(/^##\s+(.+?)\s*$/m)?.[1] ?? '',
    html: (await mdProcessor.render(chunk)).code,
  })),
);
const byId = new Map(nodes.map((n) => [n.id, n]));
const backlinks = backlinksFor(graph, '/wiki/web4').map((n) => ({ id: n.id, label: n.label }));
const outlinks = (graph.linksOut.get('/wiki/web4') ?? [])
  .map((t) => byId.get(t))
  .filter(Boolean)
  .map((n) => ({ id: n.id, label: n.label }));
// Live connection stats for the hero (same strip pattern as /, /wiki, /docs). Total outbound
// links only — a direct-docs "sources" count undersells synthesis pages that cite through
// intermediate wiki pages.
const stats = [
  { n: outlinks.length, label: 'Links to' },
  { n: backlinks.length, label: 'Referenced by' },
].filter((s) => s.n > 0);

// "On this page" links from the rendered markdown's h2/h3.
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
const hasLinks = outlinks.length > 0 || backlinks.length > 0;
const hasNav = toc.length > 1 || hasLinks;

// Page-specific FAQ (visible below + FAQPage schema), grounded in this wiki page.
// Distinct from the about/ and calcompute/ FAQs.
const FAQ = [
  {
    q: 'What is Web 4.0?',
    a: 'Web 4.0 — the Independent Internet — is a resilient, self-hosted internet that people own, run, and control themselves. It is private by design rather than by policy, keeps working when the grid goes down, and answers to the communities who use it instead of to platforms or advertisers.',
  },
  {
    q: 'What is the difference between Web 3.0 and Web 4.0?',
    a: 'Web 3.0 brought ownership through blockchain and machine-readable data; Web 4.0 adds control of the compute and data underneath — the axis every prior era left open.',
  },
  {
    q: 'What technologies does Web 4.0 use?',
    a: 'Self-hosting, peer-to-peer mesh networking (LoRaWAN / Meshtastic), post-quantum cryptography, low-earth-orbit satellite and community connectivity, and energy-efficient, offline-first systems that keep working on limited power or no connection at all.',
  },
  {
    q: 'What principles does Web 4.0 stand for?',
    a: 'Six: trustless (cryptographic verification, no intermediaries), ownership (real control of digital assets), safe (airgap-first nodes and modern encryption), ethical (federated, accountable nodes), equitable (equal participation regardless of resources), and sustainable (local processing that cuts energy and latency).',
  },
];

const web4Url = 'https://ap0110.org/wiki/web4';
const web4Schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'DefinedTerm',
      '@id': `${web4Url}#term`,
      name: 'Web 4.0 (Independent Internet)',
      description:
        'A resilient, self-hosted internet that people own, run, and control themselves — private by design, built for everyone, and answerable to the communities who use it.',
      inDefinedTermSet: {
        '@type': 'DefinedTermSet',
        name: 'AP0110 Independent Internet wiki',
        url: 'https://ap0110.org/wiki/',
      },
    },
    {
      '@type': 'Article',
      '@id': `${web4Url}#article`,
      headline: entry.data.title,
      name: entry.data.title,
      description: entry.data.description,
      url: web4Url,
      mainEntityOfPage: web4Url,
      datePublished: entry.data.date.toISOString().slice(0, 10),
      dateModified: (entry.data.updated ?? entry.data.date).toISOString?.().slice(0, 10),
      author: { '@id': 'https://ap0110.org/#organization' },
      publisher: { '@id': 'https://ap0110.org/#organization' },
      about: { '@id': `${web4Url}#term` },
      breadcrumb: {
        '@type': 'BreadcrumbList',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://ap0110.org' },
          { '@type': 'ListItem', position: 2, name: 'Wiki', item: 'https://ap0110.org/wiki' },
          { '@type': 'ListItem', position: 3, name: 'Web 4.0', item: web4Url },
        ],
      },
    },
    {
      '@type': 'FAQPage',
      '@id': `${web4Url}#faq`,
      mainEntity: FAQ.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};
---

<Layout
  title={`${entry.data.title} — AP0110.ORG Wiki`}
  description={entry.data.description}
  keywords="Web 4.0, Independent Internet, decentralized internet, self-hosted internet, mesh networking, post-quantum security, user-owned internet, Read-Write-Own-Control, AP0110"
  jsonLd={[web4Schema]}
>
  <div class="wp-paper min-h-screen">
    {/* Hero: the concept beside the full knowledge graph */}
    <section class="pt-32 pb-8 px-4">
      <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-8 lg:gap-12 items-center">
        <div>
          <a href="/wiki/" class="inline-flex items-center gap-2 text-ap-cyan hover:text-ap-cyan/80 text-sm mb-6 group">
            <svg class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Wiki
          </a>
          <div class="text-xs uppercase tracking-wide text-gray-500 mb-2">{entry.data.type}</div>
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 mb-2">{entry.data.title}</h1>
          <p class="text-ap-cyan font-medium mb-4">Built for people.</p>
          {entry.data.description && <p class="text-gray-600 text-lg leading-relaxed mb-4">{entry.data.description}</p>}
          {stats.length > 0 && (
            <div class="flex items-stretch divide-x divide-gray-200 mb-5">
              {stats.map((s) => (
                <div class="px-4 sm:px-6 first:pl-0">
                  <div class="text-2xl sm:text-3xl font-bold text-gray-900 tabular-nums">{s.n}</div>
                  <div class="text-xs uppercase tracking-wide text-gray-500 mt-1">{s.label}</div>
                </div>
              ))}
            </div>
          )}
          <div class="flex flex-wrap items-center gap-3 text-sm text-gray-500">
            {entry.data.tags.map((tag) => (
              <a href={`/wiki/tag/${tag}/`} class="bg-ap-cyan/10 text-ap-cyan px-2 py-0.5 rounded-full text-xs font-medium hover:bg-ap-cyan/20">{tag}</a>
            ))}
          </div>
        </div>
        {nodes.length > 0 && (
          <figure class="wp-fig !my-0">
            <WikiGraph data={{ nodes, edges }} client:load />
            <figcaption>The live research graph — every source and synthesis, linked. Hover to spotlight, click to read.</figcaption>
          </figure>
        )}
      </div>
    </section>

    {/* Globe banner — northern-hemisphere dot-map ported from AP0110.com,
        recolored for this site's light background. */}
    <section class="pb-8 px-4">
      <div class="max-w-6xl mx-auto relative h-[53vw] max-h-[480px] overflow-hidden rounded-lg bg-white border border-gray-200">
        <GlobeViewer client:visible />
      </div>
    </section>

    {/* Body: the synthesized concept in rich prose, between the docs-style rails
        (connected pages left, on-page links right) */}
    <section class="pb-16 px-4">
      <div class="max-w-6xl mx-auto lg:flex lg:gap-10 border-t border-gray-200 pt-10">
        {hasNav && (
          <aside class={`hidden lg:block w-52 shrink-0 ${hasLinks ? '' : 'xl:hidden'}`}>
            <div class="sticky top-20 max-h-[calc(100vh-6rem)] overflow-y-auto pb-8">
              <WikiNav outlinks={outlinks} backlinks={backlinks} toc={toc} tocClass="xl:hidden" />
            </div>
          </aside>
        )}

        <main class="wp-prose min-w-0 flex-1 max-w-3xl mx-auto lg:mx-0">
        {hasNav && (
          <details class="lg:hidden mb-8 rounded-lg border border-gray-200 bg-black/5">
            <summary class="cursor-pointer px-4 py-2.5 text-sm font-medium text-gray-700 select-none">On this page &amp; linked pages</summary>
            <div class="px-4 pb-4 pt-1">
              <WikiNav outlinks={outlinks} backlinks={backlinks} toc={toc} />
            </div>
          </details>
        )}

        {/* Prose rendered section-by-section so each diagram lands beside the copy it
            illustrates. Figures sit between the .article-prose blocks (not inside), so the
            article's element styles don't reach into the diagram labels. */}
        {sections.map((s) => (
          <Fragment>
            <div class="article-prose" set:html={s.html} />
            {s.heading.includes('at stake') && <div class="my-12"><PrinciplesGrid /></div>}
            {s.heading.includes('key technologies') && <figure class="wp-fig"><MeshDiagram /><figcaption>The core Web 4.0 technologies, meshed.</figcaption></figure>}
            {s.heading.includes('era by era') && <figure class="wp-fig"><VerbLadder /><figcaption>Read → Write → Own → Control, era by era.</figcaption></figure>}
          </Fragment>
        ))}

        {/* FAQ — visible, mirrors the FAQPage schema */}
        <div class="mt-12 pt-10 border-t border-gray-200">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Frequently asked questions</h2>
          <div class="space-y-3">
            {FAQ.map((f) => (
              <details class="rounded-lg border border-gray-200 bg-black/5">
                <summary class="cursor-pointer select-none px-4 py-3 font-bold text-gray-900">{f.q}</summary>
                <p class="px-4 pb-4 text-gray-700 leading-relaxed">{f.a}</p>
              </details>
            ))}
          </div>
        </div>

        {/* CTA — this is open research; guide the reader onward, over the cyan particle network (as on the old /web4) */}
        <section class="mt-12 pt-14 pb-14 px-4 border-t border-gray-200 text-center relative overflow-hidden min-h-[320px] flex flex-col justify-center">
          <div class="absolute inset-0 opacity-60"><Particles client:load /></div>
          <div class="relative z-10">
            <h2 class="text-2xl font-bold text-gray-900 mb-3">It's all in the open.</h2>
            <p class="text-gray-600 mb-6 max-w-xl mx-auto">Web 4.0 is built on research anyone can read and check. Follow it to the source, or see why we're building it.</p>
            <div class="flex flex-wrap gap-4 justify-center">
              <a href="/docs/" class="inline-flex items-center justify-center px-6 py-3 text-lg rounded-lg bg-ap-cyan text-white font-medium shadow-sm transition-all duration-200 hover:opacity-90">Explore the source library</a>
              <a href="/about/" class="inline-flex items-center justify-center px-6 py-3 text-lg rounded-lg border-2 border-ap-cyan text-ap-cyan font-medium transition-colors hover:bg-ap-cyan hover:text-white">Read our story</a>
            </div>
          </div>
        </section>

        </main>

        <WikiToc toc={toc} />
      </div>
    </section>
  </div>
</Layout>
