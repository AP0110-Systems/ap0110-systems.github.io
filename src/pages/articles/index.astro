---
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const fmt = (d) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
// Reading time from body word count (~200 wpm) — a small orientation cue for readers.
const readMins = (body) => Math.max(1, Math.round((body?.trim().split(/\s+/).length ?? 0) / 200));

const [featured, ...rest] = articles;
---

<Layout
  title="Articles — AP0110.ORG"
  description="Research, perspectives, and updates from AP0110.ORG on Independent Internet, Web 4.0, and decentralized networking."
>
  <div class="min-h-screen">
    {/* Hero: matches the Source Library / wiki heroes — eyebrow, title, one-line intro. */}
    <section class="pt-32 pb-12 px-4">
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ap-cyan mb-4">Writing</p>
        <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-5">Articles</h1>
        <p class="text-lg text-gray-600 leading-relaxed">
          Research, perspectives, and field notes from AP0110.ORG — on the Independent Internet, Web 4.0, and the open standards underneath it.
        </p>
      </div>
    </section>

    <section class="pb-20 px-4">
      <div class="max-w-4xl mx-auto">
        {articles.length === 0 ? (
          <div class="text-center py-16 rounded-xl border border-dashed border-gray-300 bg-white/50">
            <p class="text-gray-500">No articles published yet — check back soon.</p>
          </div>
        ) : (
          <div class="space-y-10">
            {/* Featured: the newest post, given a wider, higher-contrast card. */}
            <a
              href={`/articles/${featured.id}/`}
              class="group relative block rounded-xl bg-white/70 backdrop-blur-sm border border-gray-200 p-7 sm:p-9 shadow-sm hover:border-ap-cyan/40 hover:shadow-md transition-all duration-300"
            >
              <div class="flex items-center gap-3 mb-4">
                <span class="text-[0.65rem] font-semibold uppercase tracking-[0.15em] text-ap-cyan bg-ap-cyan/10 px-2.5 py-1 rounded-full">Latest</span>
                <span class="text-xs font-mono text-gray-500 tabular-nums">{fmt(featured.data.date)} · {readMins(featured.body)} min read</span>
              </div>
              <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 group-hover:text-ap-cyan transition-colors mb-3 text-balance">
                {featured.data.title}
              </h2>
              {featured.data.description && (
                <p class="text-gray-600 leading-relaxed mb-5 max-w-2xl">{featured.data.description}</p>
              )}
              <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
                {featured.data.author && <span class="text-sm text-gray-500">by {featured.data.author}</span>}
                <span class="flex flex-wrap gap-1.5">
                  {featured.data.tags.map((tag) => (
                    <span class="text-xs bg-ap-cyan/10 text-ap-cyan px-2 py-0.5 rounded-full font-medium">{tag}</span>
                  ))}
                </span>
                <span class="ml-auto inline-flex items-center gap-1.5 text-sm font-medium text-ap-cyan">
                  Read article
                  <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </span>
              </div>
            </a>

            {/* Remaining posts: responsive card grid. */}
            {rest.length > 0 && (
              <div class="grid gap-6 sm:grid-cols-2">
                {rest.map((article) => (
                  <a
                    href={`/articles/${article.id}/`}
                    class="group relative flex flex-col rounded-xl bg-white/60 backdrop-blur-sm border border-gray-200 p-6 hover:border-ap-cyan/40 hover:shadow-md transition-all duration-300"
                  >
                    <div class="text-xs font-mono text-gray-500 tabular-nums mb-2">{fmt(article.data.date)} · {readMins(article.body)} min read</div>
                    <h2 class="text-lg font-bold text-gray-900 group-hover:text-ap-cyan transition-colors mb-2 text-balance">
                      {article.data.title}
                    </h2>
                    {article.data.description && (
                      <p class="text-gray-600 text-sm leading-relaxed mb-4 line-clamp-3">{article.data.description}</p>
                    )}
                    <div class="mt-auto flex flex-wrap items-center gap-x-3 gap-y-1.5 text-xs text-gray-500">
                      {article.data.author && <span>by {article.data.author}</span>}
                      <span class="flex flex-wrap gap-1.5">
                        {article.data.tags.map((tag) => (
                          <span class="bg-ap-cyan/10 text-ap-cyan px-2 py-0.5 rounded-full font-medium">{tag}</span>
                        ))}
                      </span>
                    </div>
                  </a>
                ))}
              </div>
            )}
          </div>
        )}
      </div>
    </section>
  </div>
</Layout>
