---
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const fmt = (d) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const cardClass = 'rounded-lg transition-all duration-300 bg-black/10 backdrop-blur-md border border-black/20 p-6 group-hover:shadow-md';
---

<Layout
  title="Articles — AP0110.ORG"
  description="Research, perspectives, and updates from AP0110.ORG on Independent Internet, Web 4.0, and decentralized networking."
>
  <div class="min-h-screen">
    <section class="pt-32 pb-16 px-4">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-3">Articles</h1>
        <p class="text-lg text-gray-600 mb-12">Research, perspectives, and updates from AP0110.ORG.</p>

        {
          articles.length === 0 ? (
            <p class="text-gray-500">No articles published yet.</p>
          ) : (
            <div class="space-y-6">
              {articles.map((article) => (
                <a href={`/articles/${article.id}/`} class="block group">
                  <div class={cardClass}>
                    <div class="flex items-start justify-between gap-4">
                      <div class="flex-1 min-w-0">
                        <h2 class="text-xl font-bold text-gray-900 group-hover:text-ap-cyan transition-colors mb-2">
                          {article.data.title}
                        </h2>
                        {article.data.description && (
                          <p class="text-gray-600 text-sm leading-relaxed mb-3">{article.data.description}</p>
                        )}
                        <div class="flex flex-wrap items-center gap-3 text-xs text-gray-500">
                          <time>{fmt(article.data.date)}</time>
                          {article.data.author && <span>by {article.data.author}</span>}
                          {article.data.tags.map((tag) => (
                            <span class="bg-ap-cyan/10 text-ap-cyan px-2 py-0.5 rounded-full font-medium">{tag}</span>
                          ))}
                        </div>
                      </div>
                      <svg class="w-5 h-5 text-gray-400 group-hover:text-ap-cyan transition-colors flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          )
        }
      </div>
    </section>
  </div>
</Layout>
